<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:toolVm="clr-namespace:PhotoViewer.ViewModels.Tools"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="PhotoViewer.Views.Tools.PhotoStatsView"
             x:DataType="toolVm:PhotoStatsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#AAA" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2a2a2a" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="Foreground" Value="#EEE" />
        </Style>
        <Style Selector="ListBox.FolderList">
            <Setter Property="Background" Value="#1e1e1e" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="MaxHeight" Value="180" />
            <Setter Property="Padding" Value="4" />
        </Style>
        <Style Selector="ListBox.FolderList ListBoxItem">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ListBox.FolderList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a3a3a" />
        </Style>
        <Style Selector="ListBox.FolderList ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#303030" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,16,16,24" Spacing="0">

            <!-- 标题 -->
            <TextBlock Text="照片数据统计"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#EEE"
                       Margin="0,0,0,20" />

            <!-- 文件夹列表 -->
            <TextBlock Classes="SectionHeader" Text="文件夹" />
            <ListBox x:Name="FolderListBox"
                     Classes="FolderList"
                     ItemsSource="{Binding Folders}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{Binding}"
                                   FontSize="13"
                                   Foreground="#CCC"
                                   TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,20">
                <Button Click="OnAddFolderClick"
                        Content="添加文件夹"
                        IsEnabled="{Binding !IsRunning}" />
                <Button Click="OnRemoveFolderClick"
                        Content="移除选中"
                        IsEnabled="{Binding !IsRunning}" />
            </StackPanel>

            <!-- 文件筛选 -->
            <TextBlock Classes="SectionHeader" Text="文件筛选（逗号分隔，如 *.HIF,*.JPG）" />
            <TextBox Text="{Binding Patterns}"
                     IsEnabled="{Binding !IsRunning}"
                     Margin="0,0,0,20" />

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <Button Click="OnExportClick"
                        Content="导出 CSV"
                        IsEnabled="{Binding CanExport}" />
                <Button Click="OnCancelClick"
                        Content="取消"
                        IsVisible="{Binding IsRunning}" />
            </StackPanel>

            <!-- 状态文本 -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="13"
                       Foreground="#888"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
