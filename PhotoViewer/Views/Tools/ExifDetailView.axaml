<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PhotoViewer.ViewModels"
             xmlns:core="clr-namespace:PhotoViewer.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhotoViewer.Views.ExifDetailView"
             x:DataType="vm:ExifDetailViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.GroupHeader">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#EEE" />
            <Setter Property="Margin" Value="12,18,12,6" />
        </Style>
        <Style Selector="SelectableTextBlock.TagId">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Monospace" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style Selector="SelectableTextBlock.TagName">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#AAA" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="SelectableTextBlock.TagChinese">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="SelectableTextBlock.TagValue">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FFF" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxLines" Value="3" />
        </Style>

        <!-- 格式切换 ListBox 整体无背景 -->
        <Style Selector="ListBox.FormatSelector">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <!-- ListBoxItem 内边距和背景 -->
        <Style Selector="ListBox.FormatSelector ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.FormatSelector ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#505050" />
        </Style>
        <Style Selector="ListBox.FormatSelector ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#404040" />
        </Style>
        <Style Selector="ListBox.FormatSelector ListBoxItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- 文件名 + 格式切换 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Margin="12,12,12,4">

                <!-- 文件名（不含后缀） -->
                <TextBlock Text="{Binding BaseFileName}"
                           FontSize="14"
                           Foreground="#CCC"
                           VerticalAlignment="Center" />

                <!-- 格式选择（多格式时） -->
                <ListBox Classes="FormatSelector"
                         IsVisible="{Binding HasMultipleFormats}"
                         ItemsSource="{Binding Formats}"
                         SelectedItem="{Binding SelectedFormat}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:FormatEntry">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13"
                                       Foreground="#AAA"
                                       Margin="8,4" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 格式标签（单格式时） -->
                <TextBlock IsVisible="{Binding !HasMultipleFormats}"
                           Text="{Binding SelectedFormat.Label}"
                           FontSize="13"
                           Foreground="#888"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- 加载中提示 -->
            <TextBlock IsVisible="{Binding IsLoading}"
                       Text="加载中..."
                       FontSize="13"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="12,12" />

            <!-- 分组列表 -->
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="core:MetadataGroup">
                        <StackPanel>
                            <TextBlock Classes="GroupHeader" Text="{Binding Name}" />
                            <Border Background="#2a2a2a" CornerRadius="6" Margin="12,4" Padding="0" ClipToBounds="True">
                                <ItemsControl ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="core:MetadataTag">
                                            <StackPanel>
                                                <Grid ColumnDefinitions="60, 1, 2*, 1, 2*, 1, 3*">
                                                    <Border Grid.Column="0" Background="#222">
                                                        <SelectableTextBlock Classes="TagId" Text="{Binding TagIdHex}" />
                                                    </Border>
                                                    <Border Grid.Column="1" Width="1" Background="#3a3a3a" VerticalAlignment="Stretch" />
                                                    <SelectableTextBlock Grid.Column="2" Classes="TagName" Text="{Binding Name}" />
                                                    <Border Grid.Column="3" Width="1" Background="#3a3a3a" VerticalAlignment="Stretch" />
                                                    <SelectableTextBlock Grid.Column="4" Classes="TagChinese" Text="{Binding ChineseName}" />
                                                    <Border Grid.Column="5" Width="1" Background="#3a3a3a" VerticalAlignment="Stretch" />
                                                    <SelectableTextBlock Grid.Column="6" Classes="TagValue" Text="{Binding Value}" />
                                                </Grid>
                                                <Border Height="1" Background="#3a3a3a" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

