<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:toolVm="clr-namespace:PhotoViewer.ViewModels.Tools"
             xmlns:controls="clr-namespace:PhotoViewer.Controls"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="PhotoViewer.Views.Tools.DinoDebugView"
             x:DataType="toolVm:DinoDebugViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#AAA" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  PointerPressed="OnBackgroundPointerPressed">
        <StackPanel Margin="16,16,16,24" Spacing="0" Background="Transparent">

            <TextBlock Text="DINO 诊断"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#EEE"
                       Margin="0,0,0,12" />

            <TextBlock Text="{Binding Status}"
                       FontSize="12"
                       Foreground="#888"
                       Margin="0,0,0,16" />

            <TextBlock Classes="SectionHeader" Text="DINO patch (32×32，点击任意图设定参考点)" />
            <UniformGrid Columns="3" Margin="0,0,0,20">
                <controls:DiagnosticTile
                    Source="{Binding SourceThumbnail}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="原图缩略图"
                    TileClicked="OnTileClicked" />
                <controls:DiagnosticTile
                    Source="{Binding PcaRgbMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="PCA-RGB (前 3 主成分)"
                    TileClicked="OnTileClicked" />
                <controls:DiagnosticTile
                    Source="{Binding CosineMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    TileClicked="OnTileClicked">
                    <controls:DiagnosticTile.Label>
                        <MultiBinding StringFormat="Cosine 相似度  参考点: {0}, {1}">
                            <Binding Path="RefGridX" />
                            <Binding Path="RefGridY" />
                        </MultiBinding>
                    </controls:DiagnosticTile.Label>
                </controls:DiagnosticTile>
            </UniformGrid>

            <TextBlock Classes="SectionHeader" Text="CV 网格诊断（16×16，基于 level0）" />
            <UniformGrid Columns="3">
                <controls:DiagnosticTile
                    Source="{Binding DefocusMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="失焦 (lap × sobel, log)"
                    TileClicked="OnTileClicked" />
                <controls:DiagnosticTile
                    Source="{Binding MotionBlurMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="抖动 (低熵掩膜, τ=1.5bit)"
                    TileClicked="OnTileClicked" />
                <controls:DiagnosticTile
                    Source="{Binding PyramidMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="金字塔一致性 (lap CV)"
                    TileClicked="OnTileClicked" />
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
