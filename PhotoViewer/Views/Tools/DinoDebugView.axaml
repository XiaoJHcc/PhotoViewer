<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:toolVm="clr-namespace:PhotoViewer.ViewModels.Tools"
             xmlns:controls="clr-namespace:PhotoViewer.Controls"
             xmlns:views="clr-namespace:PhotoViewer.Views.Tools"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="PhotoViewer.Views.Tools.DinoDebugView"
             x:DataType="toolVm:DinoDebugViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#AAA" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  PointerPressed="OnBackgroundPointerPressed">
        <StackPanel Margin="16,16,16,24" Spacing="0" Background="Transparent">

            <TextBlock Text="DINO 诊断"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#EEE"
                       Margin="0,0,0,12" />

            <TextBlock Text="{Binding Status}"
                       FontSize="12"
                       Foreground="#888"
                       Margin="0,0,0,16" />

            <TextBlock Classes="SectionHeader" Text="DINO patch (32×32，点击任意图设定参考点)" />
            <UniformGrid Columns="3" Margin="0,0,0,20">
                <controls:DiagnosticTile
                    Source="{Binding SourceThumbnail}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="原图缩略图"
                    TileClicked="OnTileClicked" />
                <controls:DiagnosticTile
                    Source="{Binding PcaRgbMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="PCA-RGB (前 3 主成分)"
                    TileClicked="OnTileClicked" />
                <controls:DiagnosticTile
                    Source="{Binding CosineMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    TileClicked="OnTileClicked">
                    <controls:DiagnosticTile.Label>
                        <MultiBinding StringFormat="Cosine 相似度  参考点: {0}, {1}">
                            <Binding Path="RefGridX" />
                            <Binding Path="RefGridY" />
                        </MultiBinding>
                    </controls:DiagnosticTile.Label>
                </controls:DiagnosticTile>
            </UniformGrid>

            <TextBlock Classes="SectionHeader" Text="CV 网格诊断（32×32 中心采样，像素单位）" />
            <UniformGrid Columns="3">
                <controls:DiagnosticTile
                    Source="{Binding SharpnessMap}"
                    AspectRatio="{Binding AspectRatio}"
                    Crosshair="{Binding Crosshair}"
                    Label="锐度 (edge_width_p20, 1.5-10 px)"
                    TileClicked="OnTileClicked" />
                <Border Background="#151515"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Margin="4">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="220" Height="220"
                                Background="#222"
                                CornerRadius="2"
                                ClipToBounds="True">
                            <views:ShakeFieldView ShakeField="{Binding ShakeField}"
                                                  AspectRatio="{Binding AspectRatio}" />
                        </Border>
                        <TextBlock Text="抖动矢量场 (shake_spread / direction)"
                                   FontSize="12"
                                   Foreground="#888"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="#151515"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Margin="4">
                    <StackPanel HorizontalAlignment="Center" Width="220">
                        <Border Background="#222"
                                CornerRadius="2"
                                Padding="12"
                                MinHeight="220">
                            <TextBlock Text="{Binding RigidMotionText}"
                                       FontSize="12"
                                       Foreground="#DDD"
                                       FontFamily="Consolas,Menlo,monospace"
                                       LineHeight="20"
                                       TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Text="刚体拟合 (|T| / |ω| / residual)"
                                   FontSize="12"
                                   Foreground="#888"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
