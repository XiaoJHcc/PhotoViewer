<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:PhotoViewer.Views"
             xmlns:vm="clr-namespace:PhotoViewer.ViewModels.Main.File"
             xmlns:sim="clr-namespace:PhotoViewer.Core.AI"
             xmlns:behaviors="clr-namespace:PhotoViewer.Behaviors"
             xmlns:converters="clr-namespace:PhotoViewer.Converters"
             mc:Ignorable="d" d:DesignWidth="160" d:DesignHeight="400"
             x:Class="PhotoViewer.Views.Main.File.SimilarityListView"
             x:DataType="vm:SimilarityPanelViewModel">

    <UserControl.Resources>
        <local:BoolToCurrentBorderConverter x:Key="BoolToBorderConverter" />
        <local:BoolToCachedBorderConverter x:Key="CachedBorderConverter" />
        <local:FlipTransformConverter x:Key="FlipTransformConverter" />
        <local:StarColorConverter x:Key="StarColorConverter" />
        <local:SimilarityScoreConverter x:Key="SimilarityScoreConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.SimStarButton">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.SimStarButton:pointerover">
            <Setter Property="Background" Value="#333" />
        </Style>

        <Style Selector="Button.SimStarButton:disabled">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>

        <Style Selector="Button.SimStarButton:disabled:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TextBlock.SimStarButtonSymbol">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontFamily" Value="{StaticResource UiconsFontSolidStraight}" />
        </Style>

        <Style Selector="Button.SimActionButton">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#CCC" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.SimActionButton:pointerover">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
    </UserControl.Styles>

    <Grid MinWidth="120">

        <!-- ── Empty 态：无任何特征入库 ── -->
        <StackPanel IsVisible="{Binding IsStateEmpty}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10"
                    Margin="12">
            <TextBlock Text="尚未提取特征"
                       FontSize="11"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
            <Button Classes="SimActionButton"
                    Command="{Binding StartIndexingCommand}"
                    Content="提取全部" />
        </StackPanel>

        <!-- ── Partial 态：部分入库 ── -->
        <StackPanel IsVisible="{Binding IsStatePartial}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10"
                    Margin="12">
            <TextBlock FontSize="11"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <Run Text="还有 " />
                <Run Text="{Binding UnindexedCount}" />
                <Run Text=" 张未提取" />
            </TextBlock>
            <Button Classes="SimActionButton"
                    Command="{Binding StartIndexingCommand}"
                    Content="补齐全部" />

            <!-- Partial 态下仍显示已有的相似结果 -->
            <ScrollViewer Name="SimilarityScrollViewerPartial"
                          IsVisible="{Binding HasItems}"
                          HorizontalScrollBarVisibility="{Binding IsVerticalLayout,
                                Converter={x:Static converters:ScrollBarVisibilityConverter.Instance}}"
                          VerticalScrollBarVisibility="{Binding IsVerticalLayout,
                                Converter={x:Static converters:ScrollBarVisibilityConverter.Instance},
                                ConverterParameter=Reverse}"
                          MaxHeight="400">
                <Interaction.Behaviors>
                    <behaviors:HorizontalScrollWheelBehavior IsEnabled="{Binding !IsVerticalLayout}" />
                </Interaction.Behaviors>
                <ItemsControl ItemsSource="{Binding SimilarItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel
                                HorizontalAlignment="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsVerticalLayout,
                                    Converter={x:Static converters:VerticalLayoutAlignmentConverter.Instance}}"
                                Orientation="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsVerticalLayout,
                                    Converter={x:Static converters:LayoutOrientationConverter.Instance}}"
                                Margin="0,0,0,4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="sim:SimilarityItem">
                            <Button
                                Command="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).SelectItemCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="3"
                                Padding="0"
                                CornerRadius="8">
                                <Border BorderThickness="2"
                                        BorderBrush="{Binding File.IsCurrentImage, Converter={StaticResource BoolToBorderConverter}}"
                                        CornerRadius="7"
                                        Width="90"
                                        Height="138"
                                        Background="#222">
                                    <StackPanel Orientation="Vertical"
                                                HorizontalAlignment="Center"
                                                Margin="0,3,0,0"
                                                Spacing="4">
                                        <Border Width="80" Height="80" Background="#333" CornerRadius="4">
                                            <Grid>
                                                <Image Source="{Binding File.Thumbnail}"
                                                       Stretch="Uniform"
                                                       IsVisible="{Binding File.Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <Image.RenderTransform>
                                                        <TransformGroup>
                                                            <RotateTransform Angle="{Binding File.RotationAngle}" />
                                                            <ScaleTransform ScaleX="{Binding File.NeedsHorizontalFlip, Converter={StaticResource FlipTransformConverter}}" ScaleY="1" />
                                                        </TransformGroup>
                                                    </Image.RenderTransform>
                                                </Image>
                                                <TextBlock Text="📷" FontSize="24"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="#666"
                                                           IsVisible="{Binding File.ShowThumbnailPlaceholder}" />
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding File.DisplayName}"
                                                   FontSize="10" Foreground="#EEE" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="90" />
                                        <TextBlock Text="{Binding Score, Converter={StaticResource SimilarityScoreConverter}}"
                                                   FontSize="9" Foreground="#AAA" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- ── Indexing 态：正在批量提取 ── -->
        <StackPanel IsVisible="{Binding IsStateIndexing}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Margin="12">
            <TextBlock Text="正在提取特征…"
                       FontSize="11"
                       Foreground="#888"
                       HorizontalAlignment="Center" />
            <ProgressBar Value="{Binding IndexProgress}"
                         Maximum="{Binding IndexTotal}"
                         Width="100"
                         Height="6"
                         IsIndeterminate="{Binding IsIndexTotalUnknown}" />
            <TextBlock FontSize="10"
                       Foreground="#666"
                       HorizontalAlignment="Center">
                <Run Text="{Binding IndexProgress}" />
                <Run Text=" / " />
                <Run Text="{Binding IndexTotal}" />
            </TextBlock>
        </StackPanel>

        <!-- ── Full 态：全部入库，显示完整聚类列表 ── -->
        <Grid IsVisible="{Binding IsStateFull}">
            <!-- 无相似项占位 -->
            <TextBlock Text="无相似照片"
                       FontSize="11"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsEmpty}" />

            <ScrollViewer Name="SimilarityScrollViewer"
                          IsVisible="{Binding HasItems}"
                          HorizontalScrollBarVisibility="{Binding IsVerticalLayout,
                                Converter={x:Static converters:ScrollBarVisibilityConverter.Instance}}"
                          VerticalScrollBarVisibility="{Binding IsVerticalLayout,
                                Converter={x:Static converters:ScrollBarVisibilityConverter.Instance},
                                ConverterParameter=Reverse}"
                          MinHeight="148">
                <Interaction.Behaviors>
                    <behaviors:HorizontalScrollWheelBehavior IsEnabled="{Binding !IsVerticalLayout}" />
                </Interaction.Behaviors>

                <ItemsControl Name="SimilarityItemsControl"
                              ItemsSource="{Binding SimilarItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel HorizontalAlignment="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsVerticalLayout,
                                            Converter={x:Static converters:VerticalLayoutAlignmentConverter.Instance}}"
                                        Orientation="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsVerticalLayout,
                                            Converter={x:Static converters:LayoutOrientationConverter.Instance}}"
                                        Margin="10,0,10,10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="sim:SimilarityItem">
                            <Button
                                Command="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).SelectItemCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="3"
                                Padding="0"
                                CornerRadius="8"
                                HorizontalAlignment="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsVerticalLayout,
                                    Converter={x:Static converters:VerticalLayoutAlignmentConverter.Instance}}">

                                <Border BorderThickness="2"
                                        BorderBrush="{Binding File.IsCurrentImage, Converter={StaticResource BoolToBorderConverter}}"
                                        CornerRadius="7"
                                        Margin="0"
                                        Padding="0"
                                        Width="90"
                                        Height="138"
                                        Background="#222">

                                    <StackPanel Orientation="Vertical"
                                                HorizontalAlignment="Center"
                                                Margin="0,3,0,0"
                                                Spacing="4">
                                        <Border Width="80"
                                                Height="80"
                                                Background="#333"
                                                CornerRadius="4"
                                                BorderThickness="1"
                                                BorderBrush="{Binding File.IsInCache,
                                                    Converter={StaticResource CachedBorderConverter}}">
                                            <Grid>
                                                <Image Source="{Binding File.Thumbnail}"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding File.Thumbnail,
                                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <Image.RenderTransform>
                                                        <TransformGroup>
                                                            <RotateTransform Angle="{Binding File.RotationAngle}" />
                                                            <ScaleTransform
                                                                ScaleX="{Binding File.NeedsHorizontalFlip,
                                                                Converter={StaticResource FlipTransformConverter}}"
                                                                ScaleY="1" />
                                                        </TransformGroup>
                                                    </Image.RenderTransform>
                                                </Image>

                                                <ProgressBar IsVisible="{Binding File.IsThumbnailLoading}"
                                                             IsIndeterminate="True"
                                                             Width="60"
                                                             Height="4"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />

                                                <TextBlock Text="📷"
                                                           FontSize="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#666666"
                                                           IsVisible="{Binding File.ShowThumbnailPlaceholder}" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Orientation="Vertical" Spacing="2">
                                            <TextBlock Text="{Binding File.DisplayName}"
                                                       FontSize="10"
                                                       Foreground="#EEEEEE"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="90" />
                                            <TextBlock Text="{Binding Score, Converter={StaticResource SimilarityScoreConverter}}"
                                                       FontSize="9"
                                                       Foreground="#AAAAAA"
                                                       HorizontalAlignment="Center" />

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        IsVisible="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).Settings.ShowRating}">
                                                <Button Classes="SimStarButton" Tag="0" Click="OnSimStarClick">
                                                    <TextBlock Classes="SimStarButtonSymbol" Text="&#xf4f8;"
                                                               FontSize="8"
                                                               Foreground="#666"/>
                                                </Button>
                                                <Button Classes="SimStarButton" Tag="1" Click="OnSimStarClick">
                                                    <TextBlock Classes="SimStarButtonSymbol" Text="&#xfcd7;"
                                                               Foreground="{Binding File.Rating, Converter={StaticResource StarColorConverter}, ConverterParameter=1}"/>
                                                </Button>
                                                <Button Classes="SimStarButton" Tag="2" Click="OnSimStarClick">
                                                    <TextBlock Classes="SimStarButtonSymbol" Text="&#xfcd7;"
                                                               Foreground="{Binding File.Rating, Converter={StaticResource StarColorConverter}, ConverterParameter=2}"/>
                                                </Button>
                                                <Button Classes="SimStarButton" Tag="3" Click="OnSimStarClick">
                                                    <TextBlock Classes="SimStarButtonSymbol" Text="&#xfcd7;"
                                                               Foreground="{Binding File.Rating, Converter={StaticResource StarColorConverter}, ConverterParameter=3}"/>
                                                </Button>
                                                <Button Classes="SimStarButton" Tag="4" Click="OnSimStarClick">
                                                    <TextBlock Classes="SimStarButtonSymbol" Text="&#xfcd7;"
                                                               Foreground="{Binding File.Rating, Converter={StaticResource StarColorConverter}, ConverterParameter=4}"/>
                                                </Button>
                                                <Button Classes="SimStarButton" Tag="5" Click="OnSimStarClick">
                                                    <TextBlock Classes="SimStarButtonSymbol" Text="&#xfcd7;"
                                                               Foreground="{Binding File.Rating, Converter={StaticResource StarColorConverter}, ConverterParameter=5}"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
