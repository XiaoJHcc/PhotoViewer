<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PhotoViewer.ViewModels.Main.File"
             xmlns:sim="clr-namespace:PhotoViewer.Core.AI"
             xmlns:behaviors="clr-namespace:PhotoViewer.Behaviors"
             xmlns:converters="clr-namespace:PhotoViewer.Converters"
             xmlns:controls="clr-namespace:PhotoViewer.Controls"
             xmlns:viewsLocal="clr-namespace:PhotoViewer.Views"
             mc:Ignorable="d" d:DesignWidth="116" d:DesignHeight="400"
             x:Class="PhotoViewer.Views.Main.File.SimilarityListView"
             x:DataType="vm:SimilarityPanelViewModel">

    <UserControl.Resources>
        <viewsLocal:SimilarityScoreConverter x:Key="SimilarityScoreConverter" />
        <viewsLocal:SimilarityScoreToProgressFractionConverter x:Key="SimilarityScoreToProgressFractionConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- 提取/补齐按钮:宽高与列表项卡片宽 90 对齐,避免撑宽面板 -->
        <Style Selector="Button.SimActionButton">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Width" Value="90" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#CCC" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.SimActionButton:pointerover">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>

        <!-- 进度条覆盖按钮位置,同宽高;Fluent 默认 MinWidth/MinHeight 较大,这里清零让 Width/Height 真正生效 -->
        <Style Selector="ProgressBar.SimIndexProgress">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MaxWidth" Value="90" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="#4A7A4A" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <!--
        相似聚类面板外壳。
        合并后的两组正交开关:
          ShowActionArea = HasUnindexed || IsStateIndexing → 是否显示按钮/进度条区;
          HasItems                                       → 是否有列表主体。
        按"有无列表"切两套布局,避免 DockPanel 贴边导致占位文字与按钮隔开很远:
          HasItems=true : DockPanel(列表主体 + 动作区 Bottom/Right);
          HasItems=false: 单个 StackPanel 在 Border 中央,占位文字与按钮紧贴居中。
    -->
    <Border Background="#1E1E1E"
            BorderBrush="#404040"
            BorderThickness="1"
            CornerRadius="6"
            Margin="0,0,4,0"
            VerticalAlignment="{Binding IsRowLayout,
                Converter={x:Static converters:RowColVAlignmentConverter.Instance},
                ConverterParameter='Top,Stretch'}"
            MinWidth="106"
            MinHeight="154">

        <Grid>

            <!-- 无列表主体:占位文字 + 动作区 整体居中。Margin 与有列表时的卡片 margin(4) 对齐,避免按钮区出现/消失时面板宽度跳变 -->
            <StackPanel IsVisible="{Binding !HasItems}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Margin="4">
                <TextBlock IsVisible="{Binding ShowUnindexedPlaceholder}"
                           Text="尚未提取特征"
                           FontSize="11"
                           Foreground="#555"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <TextBlock IsVisible="{Binding ShowFullPlaceholder}"
                           Text="无相似照片"
                           FontSize="11"
                           Foreground="#555"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <Grid IsVisible="{Binding ShowActionArea}"
                      HorizontalAlignment="Center">
                    <Button Classes="SimActionButton"
                            IsVisible="{Binding ShowActionButton}"
                            Command="{Binding StartIndexingCommand}"
                            Content="{Binding ActionButtonText}" />
                    <Grid IsVisible="{Binding IsStateIndexing}"
                          Width="90" Height="28"
                          HorizontalAlignment="Center">
                        <ProgressBar Classes="SimIndexProgress"
                                     Value="{Binding IndexProgress}"
                                     Maximum="{Binding IndexTotal}"
                                     IsIndeterminate="{Binding IsIndexTotalUnknown}" />
                        <TextBlock FontSize="10"
                                   Foreground="#CCC"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding IndexProgress}" />
                            <Run Text=" / " />
                            <Run Text="{Binding IndexTotal}" />
                        </TextBlock>
                    </Grid>
                </Grid>
                <TextBlock IsVisible="{Binding HasIndexError}"
                           Text="{Binding IndexError}"
                           FontSize="10"
                           Foreground="#CC4444"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="120" />
            </StackPanel>

            <!-- 有列表主体:列表 + 动作区 Dock(Bottom/Right) -->
            <DockPanel IsVisible="{Binding HasItems}">
                <StackPanel DockPanel.Dock="{Binding IsRowLayout,
                                Converter={x:Static converters:DockConverter.Instance},
                                ConverterParameter='Right,Bottom'}"
                            IsVisible="{Binding ShowActionArea}"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Spacing="6"
                            Margin="{Binding IsRowLayout,
                                Converter={x:Static converters:WebMarginConverter.Instance},
                                ConverterParameter='3,3,3,8|8,3,8,3'}">
                    <TextBlock FontSize="10"
                               Foreground="#777"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center">
                        <Run Text="{Binding UnindexedCount}" />
                        <Run Text=" 张未提取" />
                    </TextBlock>
                    <Grid HorizontalAlignment="Center">
                        <Button Classes="SimActionButton"
                                IsVisible="{Binding ShowActionButton}"
                                Command="{Binding StartIndexingCommand}"
                                Content="{Binding ActionButtonText}" />
                        <Grid IsVisible="{Binding IsStateIndexing}"
                              Width="90" Height="28"
                              HorizontalAlignment="Center">
                            <ProgressBar Classes="SimIndexProgress"
                                         Value="{Binding IndexProgress}"
                                         Maximum="{Binding IndexTotal}"
                                         IsIndeterminate="{Binding IsIndexTotalUnknown}" />
                            <TextBlock FontSize="10"
                                       Foreground="#CCC"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding IndexProgress}" />
                                <Run Text=" / " />
                                <Run Text="{Binding IndexTotal}" />
                            </TextBlock>
                        </Grid>
                    </Grid>
                </StackPanel>

                <ScrollViewer Name="SimilarityScrollViewer"
                              HorizontalScrollBarVisibility="{Binding IsRowLayout,
                                    Converter={x:Static converters:ScrollBarVisibilityConverter.Instance}}"
                              VerticalScrollBarVisibility="{Binding IsRowLayout,
                                    Converter={x:Static converters:ScrollBarVisibilityConverter.Instance},
                                    ConverterParameter=Reverse}">
                    <Interaction.Behaviors>
                        <behaviors:HorizontalScrollWheelBehavior IsEnabled="{Binding IsRowLayout}" />
                    </Interaction.Behaviors>

                    <ItemsControl Name="SimilarityItemsControl"
                                  ItemsSource="{Binding SimilarItems}"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel
                                    HorizontalAlignment="Left"
                                    Margin="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsRowLayout,
                                        Converter={x:Static converters:WebMarginConverter.Instance},
                                        ConverterParameter='4,4,4,4|4,4,8,4'}"
                                    Orientation="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).IsRowLayout,
                                        Converter={x:Static converters:LayoutOrientationConverter.Instance}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sim:SimilarityItem">
                                <controls:ThumbnailCard
                                    File="{Binding File}"
                                    IsSelected="{Binding File.IsCurrentImage}"
                                    SecondLineText="{Binding Score, Converter={StaticResource SimilarityScoreConverter}}"
                                    SecondLineProgress="{Binding Score, Converter={StaticResource SimilarityScoreToProgressFractionConverter}}"
                                    ShowRating="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).Settings.ShowRating}"
                                    SelectCommand="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).SelectItemCommand}"
                                    SelectCommandParameter="{Binding}"
                                    Main="{Binding $parent[UserControl].((vm:SimilarityPanelViewModel)DataContext).Main}"
                                    HorizontalAlignment="Left" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
