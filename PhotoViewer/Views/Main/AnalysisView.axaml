<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PhotoViewer.ViewModels.Main"
             xmlns:controls="clr-namespace:PhotoViewer.Controls"
             xmlns:converters="clr-namespace:PhotoViewer.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="160"
             x:Class="PhotoViewer.Views.AnalysisView"
             x:DataType="vm:AnalysisViewModel">

    <UserControl.Resources>
        <controls:DetailPreviewHighlightGroup x:Key="SharedHighlightGroup" />
    </UserControl.Resources>

    <Border Padding="10" PointerPressed="OnBackgroundPointerPressed">
        <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="{Binding IsRowLayout, Converter={x:Static converters:LayoutOrientationConverter.Instance}}"
                                Spacing="8" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.DataTemplates>
                <DataTemplate DataType="{x:Type vm:AnalysisDetailItem}">
                    <controls:DetailPreview Width="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).PreviewSize}"
                                            Height="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).PreviewSize}"
                                            CropSize="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).CropSize}"
                                            IsActive="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).IsAnalysisViewVisible}"
                                            HighlightTarget="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).ImageVM}"
                                            HighlightGroup="{StaticResource SharedHighlightGroup}"
                                            Source="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).SourceBitmap}"
                                            Label="{Binding ShortLabel}"
                                            Center="{Binding Center}"
                                            FocusFrame="{Binding FocusFrame}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AnalysisDiagnosticItem}">
                    <controls:DiagnosticTile Width="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).PreviewSize}"
                                             Source="{Binding Source}"
                                             BackgroundSource="{Binding BackgroundSource}"
                                             Overlay="{Binding Overlay}"
                                             PlaceholderText="{Binding PlaceholderText}"
                                             CornerLabel="{Binding ShortLabel}"
                                             AspectRatio="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).AspectRatio}"
                                             Crosshair="{Binding $parent[UserControl].((vm:AnalysisViewModel)DataContext).Crosshair}"
                                             TileClicked="OnTileClicked" />
                </DataTemplate>
            </ItemsControl.DataTemplates>
        </ItemsControl>
    </Border>
</UserControl>
