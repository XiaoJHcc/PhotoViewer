<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="90" d:DesignHeight="90"
             x:Class="PhotoViewer.Controls.DetailPreview"
             x:Name="Root">

    <Border x:Name="RootBorder"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="6">
        <Border Background="#222"
                CornerRadius="5"
                ClipToBounds="True">
            <Grid>
                <Image x:Name="PreviewImage"
                       Source="{Binding Source, ElementName=Root}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />

                <Border Background="#88000000"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Padding="8,4"
                        CornerRadius="5,0,5,0">
                    <TextBlock Text="{Binding Label, ElementName=Root}"
                               FontSize="12"
                               Foreground="#aaffffff" />
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>
