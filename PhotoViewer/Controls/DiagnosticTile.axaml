<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="220" d:DesignHeight="240"
             x:Class="PhotoViewer.Controls.DiagnosticTile"
             x:Name="TileRoot"
             UseLayoutRounding="True">

    <!--
        诊断瓦片视觉与 DetailPreview 一致(嵌套圆角结构):
        - 最外 SquareFrame: BorderBrush=#444 / Thickness=1 / CornerRadius=6 的正方形,
          Background=#222 作为 letterbox 填色,ClipToBounds 用于裁剪内容。
        - 内层 InnerClip: CornerRadius=5 的 Border(无 Stroke,只是为了把内容圆角化裁切),
          与 DetailPreview 的内 Border 配对一致。
        - ContentArea 在 InnerClip 内,按 AspectRatio letterbox 居中,显示主图/PCA/cosine。
        - 左上角药丸标签 CornerLabelHost 悬挂在 SquareFrame 顶层(不挂在 ContentArea 上),
          CornerRadius=5,0,5,0 + 无 margin,与 DetailPreview 完全一致。
        - 整个瓦片吃掉所有 PointerPressed,仅 ContentArea 内点击才把归一化坐标抛给上层。
        - 底部 Label 仅在 Label 非空时显示;分析栏不传 Label,DINO 诊断工具页仍可传。
    -->
    <StackPanel x:Name="OuterStack"
                HorizontalAlignment="Stretch">
        <Border x:Name="SquareFrame"
                Background="#222"
                BorderBrush="#444"
                BorderThickness="1"
                CornerRadius="6"
                HorizontalAlignment="Stretch"
                ClipToBounds="True">
            <Grid>
                <Border x:Name="InnerClip"
                        Background="#222"
                        CornerRadius="5"
                        ClipToBounds="True">
                    <Grid x:Name="ContentArea"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Background="#222"
                          ClipToBounds="True">
                        <Image x:Name="BackgroundImage"
                               Source="{Binding BackgroundSource, ElementName=TileRoot}"
                               Stretch="Fill"
                               Opacity="0.30"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <Image x:Name="ContentImage"
                               Source="{Binding Source, ElementName=TileRoot}"
                               Stretch="Fill"
                               Opacity="{Binding ContentOpacity, ElementName=TileRoot}"
                               RenderOptions.BitmapInterpolationMode="None" />
                        <ContentPresenter x:Name="OverlayHost"
                                          Content="{Binding Overlay, ElementName=TileRoot}" />
                        <TextBlock x:Name="PlaceholderBlock"
                                   IsHitTestVisible="False"
                                   IsVisible="False"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#777"
                                   TextAlignment="Center" />
                        <Canvas x:Name="CrosshairCanvas"
                                IsHitTestVisible="False"
                                IsVisible="False">
                            <Rectangle x:Name="VMain" Fill="White" Width="1" />
                            <Rectangle x:Name="HMain" Fill="White" Height="1" />
                        </Canvas>
                    </Grid>
                </Border>
                <Border x:Name="CornerLabelHost"
                        IsHitTestVisible="False"
                        IsVisible="False"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#88000000"
                        Padding="8,4"
                        CornerRadius="5,0,5,0">
                    <TextBlock x:Name="CornerLabelBlock"
                               FontSize="12"
                               Foreground="#aaffffff" />
                </Border>
            </Grid>
        </Border>
        <TextBlock x:Name="LabelBlock"
                   Text="{Binding Label, ElementName=TileRoot}"
                   IsVisible="False"
                   FontSize="12"
                   Foreground="#888"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="4,6,4,4" />
    </StackPanel>
</UserControl>
