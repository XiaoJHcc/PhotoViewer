<?xml version="1.0" encoding="utf-8" ?>
<linker>
  <!-- Preserve user assemblies that rely on reflection (ViewLocator, DI, ReactiveUI) -->
  <assembly fullname="PhotoViewer" preserve="all" />
  <assembly fullname="PhotoViewer.iOS" preserve="all" />

  <!-- ReactiveUI uses reflection extensively -->
  <assembly fullname="ReactiveUI" preserve="all" />
  <assembly fullname="Avalonia.ReactiveUI" preserve="all" />

  <!-- MetadataExtractor / XmpCore use reflection for metadata parsing -->
  <assembly fullname="MetadataExtractor" preserve="all" />
  <assembly fullname="XmpCore" preserve="all" />

  <!-- DI container uses reflection -->
  <assembly fullname="Microsoft.Extensions.DependencyInjection" preserve="all" />
  <assembly fullname="Microsoft.Extensions.DependencyInjection.Abstractions" preserve="all" />
</linker>

